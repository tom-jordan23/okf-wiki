# External gateway profile -- the platform team's shared LiteLLM + MCP AI gateway
# (or any other OpenAI-compatible endpoint you've been given access to).
# Copy to `chat/.env` and fill in. NEVER commit a filled-in copy (see .gitignore).
#
#   cp chat/gateways/external.env.example chat/.env
#   python3 chat/run_poc.py --env-file chat/.env
#
# Confirm three things with the platform team (ADR-0003 open question "Platform gateway"):
#   1. the base URL of their OpenAI-format endpoint,
#   2. the virtual key issued to this project (spend is tracked against it),
#   3. the model name/alias to request.
# If all three match this contract, switching from internal to external is only this file.

OKF_CHAT_GATEWAY=external
OKF_CHAT_BASE_URL=https://REPLACE-with-platform-gateway.example/v1
OKF_CHAT_API_KEY=REPLACE-with-your-virtual-key
OKF_CHAT_MODEL=REPLACE-with-approved-model-name

# --- Voice (ADR-0004), only needed for run_voice_poc.py -----------------------------
# Confirm with the platform team that their gateway exposes /audio/transcriptions and
# /audio/speech, and which STT/TTS model names to request. Same base URL + virtual key.
OKF_CHAT_STT_MODEL=REPLACE-with-approved-stt-model
OKF_CHAT_TTS_MODEL=REPLACE-with-approved-tts-model
OKF_CHAT_TTS_VOICE=alloy
OKF_CHAT_TTS_FORMAT=mp3
