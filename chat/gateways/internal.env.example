# Internal gateway profile -- self-hosted LiteLLM proxy.
# Copy to `chat/.env` and fill in. NEVER commit a filled-in copy (see .gitignore).
#
#   cp chat/gateways/internal.env.example chat/.env
#   python3 chat/run_poc.py --env-file chat/.env

OKF_CHAT_GATEWAY=internal
OKF_CHAT_BASE_URL=http://localhost:4000
OKF_CHAT_API_KEY=sk-local-dev-please-change
# The model *alias* declared in internal.litellm.yaml (not the underlying provider name):
OKF_CHAT_MODEL=okf-chat-model
