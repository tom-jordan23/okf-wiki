# deploy/.env -- generated by `python3 deploy/bootstrap.py`; you can also copy this file.
# NEVER commit the filled-in .env (it holds keys + the access token). See .gitignore.

# --- profile selection (set by bootstrap) -------------------------------------------
# hosted    -> OKF_GATEWAY_CONFIG=litellm.hosted.yaml   ; `docker compose up`
# no-egress -> OKF_GATEWAY_CONFIG=litellm.no-egress.yaml ; `docker compose --profile no-egress up`
OKF_COMPOSE_PROFILE=hosted
OKF_GATEWAY_CONFIG=litellm.hosted.yaml

# --- app ----------------------------------------------------------------------------
OKF_CHAT_PORT=8080
OKF_CHAT_MODEL=okf-chat-model        # the gateway alias the loop asks for
OKF_CHAT_STT_MODEL=okf-stt-model     # leave BLANK to disable voice
OKF_CHAT_TTS_MODEL=okf-tts-model     # leave BLANK to disable voice
OKF_CHAT_TTS_VOICE=alloy
OKF_CHAT_TTS_FORMAT=mp3
# Access floor: who can use the assistant. If blank the server runs OPEN (localhost only!).
OKF_CHAT_ACCESS_TOKEN=

# --- gateway auth -------------------------------------------------------------------
# The app authenticates to the gateway with this key (LiteLLM master_key / a virtual key).
OKF_CHAT_API_KEY=sk-change-me
MASTER_KEY=sk-change-me

# --- HOSTED profile: approved-cloud provider keys (only what your config uses) -------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- NO-EGRESS profile: local model settings ---------------------------------------
OKF_WHISPER_MODEL=base               # tiny | base | small | medium | large-v3
# The LLM alias in litellm.no-egress.yaml must match a model you have pulled:
#   docker compose exec ollama ollama pull llama3.1:8b-instruct
